<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.leo.medical.mapper.SpecialTagMapper">

<!--    批量插入特长标签数据-->
    <insert id="insertBatch">
        insert into doctor_flavor (doctor_id, name, value) VALUES
             <foreach collection="flavors" separator="," item="item">
                 (#{item.doctorId},#{item.name},#{item.value})
             </foreach>
    </insert>

<!--    删除菜单关联的特长标签数据-->
    <delete id="deleteByDoctorId">
        delete
        from doctor_flavor
        where doctor_id =#{id} ;
    </delete>

<!--    根据医生id查询特长标签数据-->
    <select id="getByDoctorId" resultType="com.leo.medical.entity.SpecialTag">
        select *
        from doctor_flavor where doctor_id=#{doctorId};
    </select>
</mapper>
